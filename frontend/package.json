{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run validate:lessons:portable && vite build",
    "lint": "eslint .",
    "validate:lessons:portable": "node scripts/validate-training-lessons.mjs",
    "validate:lessons": "npm run validate:lessons:portable && ../.venv/bin/python ../backend/validate_training_lessons.py",
    "validate:lesson-accuracy": "../.venv/bin/python ../backend/validate_training_lessons.py --require-stockfish --nodes 50000",
    "validate:teaching-smoke": "../.venv/bin/python ../backend/teaching_accuracy_benchmark.py --profile smoke",
    "validate:teaching-accuracy": "../.venv/bin/python ../backend/teaching_accuracy_benchmark.py --profile release",
    "validate:learning": "node scripts/validate-learning-progress.mjs",
    "preview": "vite preview"
  },
  "dependencies": {
    "axios": "^1.13.2",
    "chess.js": "^1.4.0",
    "react": "^19.2.0",
    "react-chessboard": "^4.7.3",
    "react-dom": "^19.2.0",
    "recharts": "^3.6.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "vite": "^7.2.4"
  }
}
